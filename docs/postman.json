{
    "info": {
      "_postman_id": "b1c0d7b3-0000-0000-0000-fx-trading-backend",
      "name": "FX Trading Backend",
      "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
      "description": "Postman collection for the FX Trading Backend API: auth, wallet, FX rates, transactions, analytics, and health."
    },
    "item": [
      {
        "name": "Authentication",
        "item": [
          {
            "name": "Register new user (email + password)",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "url": {
                "raw": "{{baseUrl}}/auth/register",
                "host": ["{{baseUrl}}"],
                "path": ["auth", "register"]
              },
              "body": {
                "mode": "raw",
                "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"StrongP@ssw0rd\"\n}"
              },
              "description": "Register a new user with email and password. Sends an email OTP for verification."
            },
            "response": []
          },
          {
            "name": "Verify email with OTP",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "url": {
                "raw": "{{baseUrl}}/auth/verify",
                "host": ["{{baseUrl}}"],
                "path": ["auth", "verify"]
              },
              "body": {
                "mode": "raw",
                "raw": "{\n  \"email\": \"user@example.com\",\n  \"otp\": \"123456\"\n}"
              },
              "description": "Verify a user's email using the OTP sent after registration."
            },
            "response": []
          },
          {
            "name": "Login as user — saves accessToken",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "url": {
                "raw": "{{baseUrl}}/auth/login",
                "host": ["{{baseUrl}}"],
                "path": ["auth", "login"]
              },
              "body": {
                "mode": "raw",
                "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"StrongP@ssw0rd\"\n}"
              },
              "description": "Login with email and password to obtain a JWT access token. On success, stores the token in the `accessToken` environment variable, which is then used by all authenticated requests via collection-level and per-request Bearer auth."
            },
            "response": [],
            "event": [
              {
                "listen": "test",
                "script": {
                  "type": "text/javascript",
                  "exec": [
                    "try {",
                    "  const json = pm.response.json();",
                    "  if (json.accessToken) {",
                    "    pm.environment.set('accessToken', json.accessToken);",
                    "    console.log('accessToken set in environment');",
                    "  }",
                    "} catch (e) {",
                    "  console.warn('Could not parse login response JSON', e);",
                    "}"
                  ]
                }
              }
            ]
          },
          {
            "name": "Login as admin — saves adminAuthToken",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "url": {
                "raw": "{{baseUrl}}/auth/login",
                "host": ["{{baseUrl}}"],
                "path": ["auth", "login"]
              },
              "body": {
                "mode": "raw",
                "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"StrongP@ssw0rd\"\n}"
              },
              "description": "Login as an admin user. On success, stores the token in the `adminAuthToken` environment variable for admin-only endpoints such as /transactions/analytics."
            },
            "response": [],
            "event": [
              {
                "listen": "test",
                "script": {
                  "type": "text/javascript",
                  "exec": [
                    "try {",
                    "  const json = pm.response.json();",
                    "  if (json.accessToken) {",
                    "    pm.environment.set('adminAuthToken', json.accessToken);",
                    "    console.log('adminAuthToken set in environment');",
                    "  }",
                    "} catch (e) {",
                    "  console.warn('Could not parse admin login response JSON', e);",
                    "}"
                  ]
                }
              }
            ]
          }
        ],
        "description": "Authentication endpoints: register, verify OTP, and login."
      },
      {
        "name": "Wallet & balances",
        "item": [
          {
            "name": "Get wallet balances (all currencies)",
            "request": {
              "method": "GET",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{accessToken}}",
                  "description": "JWT access token for the authenticated user."
                }
              ],
              "url": {
                "raw": "{{baseUrl}}/wallet",
                "host": ["{{baseUrl}}"],
                "path": ["wallet"]
              },
              "description": "Get the current wallet balances for the authenticated user.\nRate limit: 30 requests per 60 seconds."
            },
            "response": []
          },
          {
            "name": "Fund wallet — deposit to a currency",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{accessToken}}",
                  "description": "JWT access token for the authenticated user."
                },
                {
                  "key": "Content-Type",
                  "value": "application/json"
                },
                {
                  "key": "Idempotency-Key",
                  "value": "9b87b9a2-4f9f-4a39-9a5e-123456789abc",
                  "description": "Unique key to make this funding operation idempotent."
                }
              ],
              "url": {
                "raw": "{{baseUrl}}/wallet/fund",
                "host": ["{{baseUrl}}"],
                "path": ["wallet", "fund"]
              },
              "body": {
                "mode": "raw",
                "raw": "{\n  \"amount\": 10000,\n  \"currency\": \"NGN\"\n}"
              },
              "description": "Fund the authenticated user's wallet in a specific currency.\nRate limit: 10 requests per 60 seconds."
            },
            "response": []
          },
          {
            "name": "Convert currency within wallet",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{accessToken}}",
                  "description": "JWT access token for the authenticated user."
                },
                {
                  "key": "Content-Type",
                  "value": "application/json"
                },
                {
                  "key": "Idempotency-Key",
                  "value": "4c4af2d0-2a59-4a2b-9e21-abcdefabcdef",
                  "description": "Unique key to make this conversion operation idempotent."
                }
              ],
              "url": {
                "raw": "{{baseUrl}}/wallet/convert",
                "host": ["{{baseUrl}}"],
                "path": ["wallet", "convert"]
              },
              "body": {
                "mode": "raw",
                "raw": "{\n  \"fromCurrency\": \"NGN\",\n  \"toCurrency\": \"USD\",\n  \"amount\": 5000\n}"
              },
              "description": "Convert funds from one currency to another (e.g., NGN to USD) within the user's wallet.\nRate limit: 20 requests per 60 seconds."
            },
            "response": []
          },
          {
            "name": "Execute trade (FX pair, recorded as TRADE)",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{accessToken}}",
                  "description": "JWT access token for the authenticated user."
                },
                {
                  "key": "Content-Type",
                  "value": "application/json"
                },
                {
                  "key": "Idempotency-Key",
                  "value": "1d8b5f0e-3a6c-4b9f-9c2d-fedcba987654",
                  "description": "Unique key to make this trade operation idempotent."
                }
              ],
              "url": {
                "raw": "{{baseUrl}}/wallet/trade",
                "host": ["{{baseUrl}}"],
                "path": ["wallet", "trade"]
              },
              "body": {
                "mode": "raw",
                "raw": "{\n  \"fromCurrency\": \"USD\",\n  \"toCurrency\": \"NGN\",\n  \"amount\": 10\n}"
              },
              "description": "Execute a trade between two currencies (same payload as convert, but recorded as a TRADE for reporting).\nRate limit: 20 requests per 60 seconds."
            },
            "response": []
          }
        ],
        "description": "Wallet operations for the authenticated user: balances, funding, conversion, and trading."
      },
      {
        "name": "Foreign exchange",
        "item": [
          {
            "name": "Get FX rates for a base currency",
            "request": {
              "method": "GET",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{accessToken}}",
                  "description": "JWT access token for the authenticated user."
                }
              ],
              "url": {
                "raw": "{{baseUrl}}/fx/rates?base=NGN",
                "host": ["{{baseUrl}}"],
                "path": ["fx", "rates"],
                "query": [
                  {
                    "key": "base",
                    "value": "NGN",
                    "description": "Base currency for FX rates (defaults to NGN if omitted)."
                  }
                ]
              },
              "description": "Fetch FX rates for the given base currency (default NGN).\nRate limit: 60 requests per 60 seconds."
            },
            "response": []
          }
        ],
        "description": "FX rate endpoints."
      },
      {
        "name": "Transactions & analytics",
        "item": [
          {
            "name": "List my transactions (filters + pagination)",
            "request": {
              "method": "GET",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{accessToken}}",
                  "description": "JWT access token for the authenticated user."
                }
              ],
              "url": {
                "raw": "{{baseUrl}}/transactions?limit=20&page=1",
                "host": ["{{baseUrl}}"],
                "path": ["transactions"],
                "query": [
                  {
                    "key": "type",
                    "value": "",
                    "disabled": true,
                    "description": "Optional: filter by type (e.g. FUND, CONVERT, TRADE)."
                  },
                  {
                    "key": "status",
                    "value": "",
                    "disabled": true,
                    "description": "Optional: filter by status (e.g. COMPLETED, PENDING)."
                  },
                  {
                    "key": "page",
                    "value": "1",
                    "description": "Optional page number (default 1)."
                  },
                  {
                    "key": "limit",
                    "value": "20",
                    "description": "Optional page size (default 20)."
                  }
                ]
              },
              "description": "List wallet transactions for the authenticated user with optional filters and pagination."
            },
            "response": []
          },
          {
            "name": "Admin: full analytics (summary, volume, daily trends)",
            "request": {
              "method": "GET",
              "header": [],
              "auth": {
                "type": "bearer",
                "bearer": [
                  {
                    "key": "token",
                    "value": "{{adminAuthToken}}",
                    "type": "string"
                  }
                ]
              },
              "url": {
                "raw": "{{baseUrl}}/transactions/analytics?from=2026-03-01&to=2026-03-31&includeDaily=true",
                "host": ["{{baseUrl}}"],
                "path": ["transactions", "analytics"],
                "query": [
                  {
                    "key": "from",
                    "value": "2026-03-01",
                    "description": "Optional start of period (ISO). Omit for all-time."
                  },
                  {
                    "key": "to",
                    "value": "2026-03-31",
                    "description": "Optional end of period (ISO). Omit for all-time."
                  },
                  {
                    "key": "includeDaily",
                    "value": "true",
                    "description": "If true with from+to, adds per-day trends (max 366-day range)."
                  }
                ]
              },
              "description": "Admin-only: summary (totals, unique wallets, by status/type, completion rates), volume by currency, breakdown by transaction type, optional daily trends. Uses `adminAuthToken`."
            },
            "response": []
          }
        ],
        "description": "Transaction history and admin analytics."
      },
      {
        "name": "System health",
        "item": [
          {
            "name": "Liveness — health check (no auth)",
            "request": {
              "method": "GET",
              "header": [],
              "url": {
                "raw": "{{baseUrl}}/health",
                "host": ["{{baseUrl}}"],
                "path": ["health"]
              },
              "description": "Basic health check endpoint for the service (no authentication required)."
            },
            "response": []
          }
        ],
        "description": "Service health check."
      }
    ],
    "event": [],
    "variable": [
      {
        "key": "baseUrl",
        "value": "http://localhost:3000",
        "type": "string"
      },
      {
        "key": "accessToken",
        "value": "",
        "type": "string"
      },
      {
        "key": "adminAuthToken",
        "value": "",
        "type": "string"
      }
    ],
    "auth": {
      "type": "bearer",
      "bearer": [
        {
          "key": "token",
          "value": "{{accessToken}}",
          "type": "string"
        }
      ]
    }
  }
